# MCP Server Environment Variables
# Copy this file to .env and fill in the values

# Polarion API Configuration
# The base URL for your Polarion REST API endpoint (required)
# Example: https://your-polarion-server/polarion/rest/v1
API_BASE_URL=https://your-polarion-instance.com/polarion/rest/v1

# Authentication
# Bearer token for Polarion API authentication
# Get this from your Polarion user settings -> Personal Access Tokens
BEARER_TOKEN=your_polarion_bearer_token_here

# HTTP Server Configuration (only needed for HTTP mode / Custom GPT)
# Port for the HTTP REST API server
# Default: 3000
HTTP_PORT=3000

# HTTP Server Authentication
# API Key for authenticating requests to the HTTP server
# This protects your HTTP endpoints from unauthorized access
# Generate a secure random key: openssl rand -hex 32
# Custom GPT will use this key with "Authorization: Bearer YOUR_API_KEY"
HTTP_API_KEY=your_secure_api_key_here

# Optional: Logging
LOG_LEVEL=info

# Optional: TLS
# Use only for trusted internal servers with self-signed certificates
NODE_TLS_REJECT_UNAUTHORIZED=0
